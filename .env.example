# Copie ce fichier en .env (a la racine) et remplis les valeurs.
# Recupere-les dans https://discord.com/developers/applications -> ton appli.

# --- Serveur (auth OAuth + websocket) ---
DISCORD_CLIENT_ID=ton_application_id
DISCORD_CLIENT_SECRET=ton_client_secret
PORT=3001

# --- Client (Vite) ---
# Doit etre le MEME que DISCORD_CLIENT_ID. Prefixe VITE_ obligatoire pour etre lisible cote client.
VITE_DISCORD_CLIENT_ID=ton_application_id
